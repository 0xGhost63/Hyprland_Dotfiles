[
    {
        "position": "top",
        "height": 30,
        "spacing": 9,
        "margin-top": 0,
        "margin-bottom": 0,
        "margin-left": 0,
        "margin-right": 0,
        "modules-left": [
            "custom/vscode",
            "hyprland/workspaces",
            "image#albumart",
            "mpris"
        ],
        "modules-center": [
            "custom/cava",
            "clock"
        ],
        "modules-right": [
            "network",
            "bluetooth",
            "pulseaudio",
            "battery",
            "cpu",
            "custom/swaync",
            "custom/power",
            "idle_inhibitor"
        ],
        "hyprland/workspaces": {
            "format": "{id}",
            "on-scroll-up": "hyprctl dispatch workspace e-1",
            "on-scroll-down": "hyprctl dispatch workspace e+1",
            "persistent-workspaces": {
                "*": [
                    1,
                    2,
                    3,
                    4,
                    5
                ]
            },
            "anim-color-1": "#00e5ff",
            "anim-color-2": "#b347ff",
            "anim-duration": 3,
            "button-radius": 15,
            "button-pad-v": 0,
            "button-pad-h": 4,
            "button-minw": 35
        },
        "hyprland/window": {
            "format": "{}",
            "max-length": 60,
            "separate-outputs": true
        },
        "custom/cava": {
            "exec": "~/.config/hypr/scripts/waybarcava.sh",
            "format": "{}",
            "tooltip": false
        },
        "clock": {
            "format": "{:%H:%M  |  %A %d %B}",
            "timezone": "Asia/Karachi",
            "locale": "en_US.utf8",
            "interval": 1,
            "on-click": "flatpak run com.ml4w.calendar",
            "tooltip": true
        },
        "cpu": {
            "format": "َ°چ› {usage}%",
            "tooltip": true,
            "interval": 2
        },
        "memory": {
            "format": "َ°¾† {used:0.1f}G",
            "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
            "interval": 5
        },
        "network": {
            "format-wifi": "َ°–© {signalStrength}%",
            "format-ethernet": "َ°ˆ€ {ipaddr}",
            "format-disconnected": "َ°–ھ Disconnected",
            "format-linked": "َ°–© No Internet",
            "format-disabled": "َ°–ھ Disabled",
            "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n{essid} ({signalStrength}%)\nâ†‘ {bandwidthUpBits}  â†“ {bandwidthDownBits}",
            "on-click": "nm-connection-editor",
            "interval": 5
        },
        "bluetooth": {
            "format": "ïٹ“",
            "format-disabled": "َ°‚³",
            "format-off": "َ°‚²",
            "format-connected": "َ°‚± {num_connections}",
            "tooltip-format": "Bluetooth: {status}",
            "tooltip-format-disabled": "Bluetooth: Disabled",
            "tooltip-format-off": "Bluetooth: Off",
            "tooltip-format-connected": "Bluetooth: Connected ({num_connections})\n{device_enumerate}",
            "tooltip-format-enumerate-connected": "ïٹ“ {device_alias}\t{device_address}",
            "tooltip": true,
            "on-click": "blueman-manager",
            "on-click-right": "python3 ~/.config/hypr/scripts/btpanel.py"
        },
        "pulseaudio": {
            "format": "{icon} {volume}%",
            "format-muted": "َ°‌ں mute",
            "format-icons": {
                "default": [
                    "َ°•؟",
                    "َ°–€",
                    "َ°•¾"
                ]
            },
            "on-click": "pavucontrol",
            "scroll-step": 5
        },
        "battery": {
            "format": "{icon} {capacity}%",
            "format-icons": [
                "َ°پ؛",
                "َ°پ¼",
                "َ°پ¾",
                "َ°‚€",
                "َ°‚‚",
                "َ°پ¹"
            ],
            "format-charging": "َ°‚„ {capacity}%",
            "format-plugged": "َ°ڑ¥ {capacity}%",
            "states": {
                "warning": 30,
                "critical": 15
            }
        },
        "mpris": {
            "format": "{player_icon} {dynamic}",
            "format-paused": "{status_icon} {dynamic}",
            "max-length": 25,
            "dynamic-len": 25,
            "dynamic-importance-order": [
                "title",
                "artist"
            ],
            "player-icons": {
                "spotify": "َ°“‡",
                "default": "â–¶"
            },
            "status-icons": {
                "paused": "âڈ¸"
            }
        },
        "privacy": {
            "icon-size": 18,
            "icon-spacing": 4,
            "transition-duration": 250,
            "_inverted": false
        },
        "tray": {
            "spacing": 8,
            "icon-size": 18
        },
        "custom/arch": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 22' color='#00e5ff'>َ°£‡</span>",
            "on-click": "$HOME/.local/bin/vsfetch",
            "tooltip": false,
            "arch-icon-glyph": "َ°£‡",
            "arch-pad-left": 15,
            "arch-pad-right": 10
        },
        "custom/weather": {
            "format": "{}",
            "exec": "curl -s 'https://wttr.in/Lahore?format=%c+%t' &",
            "return-type": "json",
            "interval": 1800,
            "tooltip": true,
            "on-click": "flatpak run io.github.amit9838.mousam"
        },
        "custom/updates": {
            "exec": "count=$(checkupdates 2>/dev/null | wc -l); [ \"$count\" -gt 0 ] && echo '{\"text\":\"َ°ڑ° '\"$count\"'\",\"class\":\"pending\"}' || echo '{\"text\":\"َ°ڑ° 0\",\"class\":\"updated\"}'",
            "return-type": "json",
            "interval": 60,
            "tooltip": false,
            "on-click": "kitty --class floating-terminal -e ~/.config/hypr/scripts/install-updates.sh"
        },
        "custom/swaync": {
            "tooltip": true,
            "tooltip-format": "Left Click: Launch Notification Center\nRight Click: Do not Disturb",
            "format": "{} {icon}",
            "format-icons": {
                "notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
                "none": "ï‚¢",
                "dnd-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
                "dnd-none": "ï‡·",
                "inhibited-notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
                "inhibited-none": "ï‚¢",
                "dnd-inhibited-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
                "dnd-inhibited-none": "ï‡·"
            },
            "return-type": "json",
            "exec-if": "which swaync-client",
            "exec": "swaync-client -swb",
            "on-click": "sleep 0.1 && swaync-client -t -sw",
            "on-click-right": "swaync-client -d -sw",
            "escape": true
        },
        "custom/power": {
            "format": "âڈ»",
            "on-click": "wlogout -b 3 -c 20 -r 20 -L 400 -R 400 -T 200 -B 200 --protocol layer-shell",
            "tooltip": false
        },
        "custom/settings": {
            "format": "َ°’“",
            "on-click": "vswaybar-studio",
            "tooltip": false
        },
        "custom/claudebar": {
            "exec": "claudebar --format '{session_bar} {session_pct}% آ· {session_reset}'",
            "return-type": "json",
            "interval": 30,
            "signal": 13,
            "tooltip": true,
            "on-click": "xdg-open https://claude.ai/settings/usage"
        },
        "custom/bar-cpu": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type cpu",
            "return-type": "json",
            "interval": 2,
            "tooltip": true
        },
        "custom/bar-mem": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type mem",
            "return-type": "json",
            "interval": 5,
            "tooltip": true
        },
        "custom/bar-vol": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type vol",
            "return-type": "json",
            "interval": 2,
            "tooltip": true,
            "on-click": "pavucontrol"
        },
        "custom/bar-wifi": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type wifi",
            "return-type": "json",
            "interval": 5,
            "tooltip": true,
            "on-click": "nm-connection-editor"
        },
        "custom/vscode": {
            "format": "َ°¨‍",
            "tooltip": true,
            "on-click": "code",
            "tooltip-format": "VS Code"
        },
        "image#albumart": {
            "path": "/tmp/waybar-art.png",
            "size": 28,
            "interval": 2,
            "tooltip": false,
            "on-click": "playerctl play-pause"
        },
        "name": "bar"
    },
    {
        "name": "dock",
        "position": "bottom",
        "height": 54,
        "spacing": 6,
        "layer": "top",
        "margin-top": 0,
        "margin-bottom": 8,
        "margin-left": 0,
        "margin-right": 0,
        "exclusive": false,
        "passthrough": false,
        "gtk-layer-shell": true,
        "modules-left": [],
        "modules-center": [],
        "modules-right": []
    }
]